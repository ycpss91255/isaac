#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
)

# Forklift blocky — Model A-hybrid.
# Forklift cubes: kinematic rigid bodies (driver sets pose via dc.set_kinematic_target).
# Environment (ground, pallet): dynamic + collision (real physics).
# Pallet drops to ground under gravity; forks lift pallet via collision contact.

def Xform "World"
{
    def DistantLight "SunLight"
    {
        float inputs:intensity = 3000
        float3 xformOp:rotateXYZ = (-45, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    # Ground as checkerboard 6x6 tiles (3x3m each, 18x18m total).
    # Visible grid helps eye-track forklift / pallet motion.
    def Xform "GroundTiles"
    {
        def Cube "tile_0_0" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1
            float3 xformOp:scale = (3, 3, 0.02)
            double3 xformOp:translate = (-7.50, -7.50, -0.01)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
            color3f[] primvars:displayColor = [(0.45, 0.45, 0.45)]
